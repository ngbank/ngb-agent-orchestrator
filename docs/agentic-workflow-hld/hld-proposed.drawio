                </mxCell>
                <mxCell id="EdAH23wTT8TAoaTBZzOQ-26" value="&lt;b&gt;Day 1 vs Scale&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Day 1:&lt;/b&gt; Orchestrator submits jobs via HTTP to the K8s Job Controller. Pod reports status, heartbeats, and results back through the Workflow API (never touches the State Store directly). LangGraph Checkpointer handles resume across the approval gate.&lt;br&gt;&lt;br&gt;&lt;b&gt;Scale:&lt;/b&gt; Orchestrator can publish to the bus and a Job Dispatcher pod in AKS (or KEDA ScaledJob) consumes execute-jobs messages and creates K8s Jobs. To be used when decoupling across clusters/clouds or per-message autoscaling is required.&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;Scale&lt;/b&gt;: Integrate with EQAssure&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8dc;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;spacingRight=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="2920" y="1618" width="580" height="172" as="geometry"/>
                </mxCell>
                <mxCell id="EdAH23wTT8TAoaTBZzOQ-27" style="endArrow=block;html=1;rounded=0;" parent="1" source="EdAH23wTT8TAoaTBZzOQ-12" target="EdAH23wTT8TAoaTBZzOQ-13" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="EdAH23wTT8TAoaTBZzOQ-28" style="endArrow=block;html=1;rounded=0;" parent="1" source="EdAH23wTT8TAoaTBZzOQ-13" target="EdAH23wTT8TAoaTBZzOQ-14" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="EdAH23wTT8TAoaTBZzOQ-29" value="Security / Secrets / Audit  (cross-cutting control-plane capability)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=middle;align=center;fontStyle=1;fontSize=13;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="350" width="1220" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="EdAH23wTT8TAoaTBZzOQ-30" value="&lt;b&gt;Metrics / Observability&lt;/b&gt;&amp;nbsp; (cross-cutting telemetry across control plane, execution pod, and external integrations)&lt;br&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;padding:4px 12px;font-weight:normal;&quot;&gt;&lt;b&gt;Scope (today&#39;s requirements):&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Audit log&lt;/b&gt; — immutable record of triggers, decisions, approvals, state transitions&lt;br&gt;• &lt;b&gt;Agent traces (OTel)&lt;/b&gt; — one span per LangGraph node; GenAI semantic conventions for LLM spans&lt;br&gt;• &lt;b&gt;Token usage &amp;amp; cost&lt;/b&gt; — per workflow / ticket / model / node, via LiteLLM OTel callback&lt;br&gt;• &lt;b&gt;Quality drift detection&lt;/b&gt; — validator pass rate, retry count, clarification count, PR rejection rate over time&lt;br&gt;• &lt;b&gt;Exceptions&lt;/b&gt; — captured on active span; correlated by trace_id&lt;br&gt;&lt;br&gt;&lt;b&gt;Correlation key:&lt;/b&gt; W3C trace_id + workflow_id + jira_ticket attributes on every span / log / audit event.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;align=center;fontStyle=0;fontSize=12;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1610" y="1630" width="890" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="obs-stack-note" value="&lt;b&gt;Recommended Stack&lt;/b&gt;&lt;br&gt;&lt;i&gt;Reuses existing Elastic + Sentry + OTel investment; no new vendor.&lt;/i&gt;&lt;hr&gt;&lt;table cellpadding=&quot;4&quot; cellspacing=&quot;0&quot; style=&quot;font-size:11px;border-collapse:collapse;width:100%;text-align:left;&quot;&gt;&lt;tbody&gt;&lt;tr style=&quot;background: rgb(232, 232, 232);&quot;&gt;&lt;th style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Need&lt;/th&gt;&lt;th style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Tool&lt;/th&gt;&lt;th style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Notes&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Audit log&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;&lt;b&gt;Elastic&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Structured events from state transitions; SQLite is source of truth, mirrored to Elastic&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Agent traces (OTel)&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;&lt;b&gt;Elastic APM&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;OTel SDK; one span per LangGraph node; GenAI semantic conventions&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Exceptions&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;&lt;b&gt;Sentry&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Already in use; attach trace_id so it links to Elastic&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Token usage &amp;amp; cost&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;&lt;b&gt;Elastic&lt;/b&gt; dashboard&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Built from LiteLLM OTel attributes (gen_ai.usage.*)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Quality drift dashboards&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;&lt;b&gt;Elastic&lt;/b&gt; dashboard&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Score signals: validator pass/fail, retries, clarifications, PR rejections&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Eval runner (offline)&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;&lt;b&gt;promptfoo&lt;/b&gt; / deepeval in CI&lt;/td&gt;&lt;td style=&quot;border: 1px solid rgb(153, 153, 153);&quot;&gt;Push scores to Elastic; add Langfuse later if prompt iteration becomes a team activity&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;br&gt;&lt;div style=&quot;font-size:11px;text-align:left;&quot;&gt;&lt;b&gt;Future-proofing:&lt;/b&gt; OTel pipeline is vendor-neutral. Adding Langfuse (or other LLM-trace UI) later is purely additive — fan out at the OTel Collector; no migration needed.&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=top;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1610" y="1870" width="890" height="250" as="geometry"/>
