                <mxCell id="EdAH23wTT8TAoaTBZzOQ-66" value="&lt;span style=&quot;font-weight: normal;&quot;&gt;Generate Code&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;i&gt;create K8s job&lt;/i&gt;&lt;/font&gt;&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1580" y="995" width="200" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="rev-banner" value="REVIEW ANNOTATIONS v2 — proposed changes (do not redraw the diagram yet; these are the deltas to discuss)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=middle;align=center;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="130" y="2260" width="2740" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="rev-legend" value="&lt;b&gt;Legend for annotations&lt;/b&gt;&lt;br&gt;Yellow note = open question for review&#xa;Orange callout = Lighthouse PoC scope&#xa;Faded grey = considered &amp; deferred (Phase 2+)&#xa;Inline coloured strip = marker pointing at an existing element to revisit" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1750" width="320" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="rev-lighthouse" value="&lt;b&gt;1. LIGHTHOUSE PoC — prove governance on a thin slice&lt;/b&gt;&lt;br&gt;&lt;br&gt;Scope: &lt;b&gt;Requirements → Architect → Coder → Tester&lt;/b&gt; for &lt;b&gt;one real story&lt;/b&gt;.&#xa;&#xa;&lt;b&gt;Real (not stubbed):&lt;/b&gt; Context Store, Audit Log, OPA / Policy Engine, HITL Console.&#xa;&lt;b&gt;Writes:&lt;/b&gt; branch-only (no main, no infra, no prod).&#xa;&lt;b&gt;Everything else read-only.&lt;/b&gt;&#xa;&#xa;Gate to expand: must survive a compliance review.&#xa;Everything outside this slice is &lt;b&gt;Phase 2+&lt;/b&gt;." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="380" y="1750" width="420" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="rev-sor" value="&lt;b&gt;2. SYSTEM OF RECORD — split by KIND of fact, not duplicate the same fact&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table cellpadding=&quot;4&quot; cellspacing=&quot;0&quot; style=&quot;border-collapse:collapse;font-size:10px;&quot;&gt;&lt;tr style=&quot;background:#f5f5f5;&quot;&gt;&lt;th align=&quot;left&quot;&gt;Kind of fact&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;SoR&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Story / requirement / AC&lt;/td&gt;&lt;td&gt;&lt;b&gt;Jira&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Workflow runtime state (gate, retry, checkpoint)&lt;/td&gt;&lt;td&gt;&lt;b&gt;State Store&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Work plans / clarifications / exec summary&lt;/td&gt;&lt;td&gt;&lt;b&gt;State Store&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Code&lt;/td&gt;&lt;td&gt;&lt;b&gt;GitHub&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;ADRs&lt;/td&gt;&lt;td&gt;&lt;b&gt;Confluence OR repo /docs&lt;/b&gt; (pick one)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Audit / decisions&lt;/td&gt;&lt;td&gt;&lt;b&gt;Audit Log (append-only)&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;Today the State Store mirrors story status from Jira but never writes it back as the source-of-truth field. Every dataset has &lt;b&gt;exactly one writer&lt;/b&gt;; other systems mirror only.&#xa;&#xa;Clean seam into Kevin&#39;s data-shift-left model." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8dc;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="150" y="2420" width="420" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="rev-sor-rule" value="&lt;b&gt;Jira owns the story. State Store owns the run. They never own the same field.&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;fontStyle=1;fontSize=14;strokeWidth=3;" parent="1" vertex="1">
                    <mxGeometry x="900" y="1820" width="420" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="rev-mcp" value="&lt;b&gt;3. MCP GOVERNANCE — ~24 write paths is an InfoSec landmine&lt;/b&gt;&lt;br&gt;&lt;br&gt;Risk: 2am incident-response pagers if MCPs are unmaintained or untrusted.&#xa;&#xa;&lt;b&gt;Required for every MCP server (manifest):&lt;/b&gt;&#xa;• Owner (team) and on-call rotation&#xa;• Source: &lt;b&gt;internal vs 3rd-party&lt;/b&gt; (3rd-party requires risk assessment)&#xa;• Maintenance status (active / deprecated / abandoned)&#xa;• &lt;b&gt;Read vs Write&lt;/b&gt; tools split (get_* vs put_*)&#xa;• Per-recipe / per-agent &lt;b&gt;allow-list&lt;/b&gt;&#xa;• Scoped credentials (no shared service accounts)&#xa;• Versioned contract + deprecation policy&#xa;&#xa;&lt;b&gt;Gate:&lt;/b&gt; no MCP enters the allow-list without manifest + InfoSec sign-off." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="2310" width="440" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="rev-gates" value="&lt;b&gt;4. GATES — &quot;every gate mandatory&quot; is throughput death&lt;/b&gt;&lt;br&gt;&lt;br&gt;Place &lt;b&gt;human (H)&lt;/b&gt; gates only at &lt;b&gt;irreversible / regulated&lt;/b&gt; boundaries. Everything else uses automated quality (G) gates.&#xa;&#xa;&lt;b&gt;H gates (mandatory, human):&lt;/b&gt;&#xa;• H-Secure — pre-merge, before Secure stage&#xa;• H-Release — pre-prod release&#xa;&#xa;&lt;b&gt;G gates (automated):&lt;/b&gt;&#xa;• G-Schema — WorkPlan validation&#xa;• G-Build — compile + unit&#xa;• G-Verify — integration / E2E&#xa;• G-Eval — scorecard threshold&#xa;&#xa;&lt;b&gt;Today&#39;s WorkPlan approval&lt;/b&gt; → demote to optional &quot;preview&quot; outside regulated paths." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="750" y="2740" width="420" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="rev-tiers" value="&lt;b&gt;5. CAPABILITY TIERS — remove model names from architecture&lt;/b&gt;&lt;br&gt;&lt;br&gt;Pinning Opus / Sonnet / GPT-x per agent &lt;b&gt;ages in weeks&lt;/b&gt; and contradicts the Model Router.&#xa;&#xa;&lt;b&gt;Abstract to capability + compliance tiers:&lt;/b&gt;&#xa;• &lt;b&gt;T1 — extraction&lt;/b&gt; (small, cheap)&#xa;• &lt;b&gt;T2 — reasoning&lt;/b&gt; (frontier, large context)&#xa;• &lt;b&gt;T3 — coding&lt;/b&gt; (code-specialised)&#xa;• &lt;b&gt;T4 — verification&lt;/b&gt; (different family from T2/T3 to avoid bias)&#xa;&#xa;&lt;b&gt;Compliance tag&lt;/b&gt; per tier: data-residency, training-opt-out, PII allowed.&#xa;&#xa;Model Router (LiteLLM) maps tier+compliance → concrete model. Diagram never mentions vendors." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="2670" width="420" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="rev-ctx" value="&lt;b&gt;6. CONTEXT STORE — where comprehension debt accumulates silently&lt;/b&gt;&lt;br&gt;&lt;br&gt;Hardest, least-glamorous, &lt;b&gt;owned by Builders (not an agent)&lt;/b&gt;.&#xa;&#xa;&lt;b&gt;Open design questions (must answer before Phase 2):&lt;/b&gt;&#xa;1. &lt;b&gt;Isolation&lt;/b&gt; — boundary per story / epic / project / tenant?&#xa;2. &lt;b&gt;Eviction policy&lt;/b&gt; — LRU? per-stage TTL? on PR-merge?&#xa;3. &lt;b&gt;What survives a full Plan→Build→Verify cycle?&lt;/b&gt; (ADRs? rejected approaches? clarifications?)&#xa;4. &lt;b&gt;Cross-story leakage&lt;/b&gt; — story A&#39;s ADR must not silently bias story B.&#xa;5. &lt;b&gt;Provenance&lt;/b&gt; — every retrieved chunk must cite source artefact + commit/version.&#xa;6. &lt;b&gt;Right to be forgotten&lt;/b&gt; — how do we purge?&#xa;&#xa;Today: Jira + cloned repo. No graph/vector store yet — &lt;b&gt;don&#39;t adopt one until #1–#6 are answered&lt;/b&gt;." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="20" y="1960" width="500" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="rev-durability" value="&lt;b&gt;7. LAYER 1 DURABILITY — validate PoC commitment vs compliance surface&lt;/b&gt;&lt;br&gt;&lt;br&gt;PoC committed to: &lt;b&gt;LangGraph + SQLite Checkpointer&lt;/b&gt;.&#xa;&#xa;&lt;b&gt;Open questions to answer before scale:&lt;/b&gt;&#xa;• Partial failure: what happens if the pod dies mid-Execute?&#xa;• Mid-workflow crash: is checkpointer state recoverable from cold-start?&#xa;• Replay: are LLM calls deterministic enough? (cache + seeded prompts)&#xa;• Audit replay-ability: can we reconstruct any past run end-to-end from the audit log alone?&#xa;&#xa;&lt;b&gt;LangGraph vs Temporal — tradeoffs:&lt;/b&gt;&#xa;• LangGraph: low ops cost, ergonomic for agent flows, in-process state, &lt;b&gt;single-node&lt;/b&gt; durability today.&#xa;• Temporal: battle-tested durable execution, multi-cluster, history-replay first-class, &lt;b&gt;higher ops cost + agent ergonomics weaker&lt;/b&gt;.&#xa;&#xa;&lt;b&gt;Decision:&lt;/b&gt; stay on LangGraph for the Lighthouse. Re-evaluate Temporal &lt;b&gt;only&lt;/b&gt; if compliance review demands cross-region durable execution or replay guarantees we cannot meet." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="610" y="2340" width="540" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="rev-ownership" value="&lt;b&gt;8. OWNERSHIP — write down who owns what (Builders vs Process Owners)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Two kinds of work hide in this diagram:&#xa;&#xa;&lt;b&gt;BUILDERS (engineering — code, schemas, durability)&lt;/b&gt;&#xa;• Context Store design + isolation + eviction&#xa;• State Store / Checkpointer / migrations&#xa;• LangGraph orchestrator nodes &amp; edges&#xa;• MCP servers (internal) + manifest schema&#xa;• Recipes (plan / execute / verify)&#xa;• LLM Gateway config + capability-tier router&#xa;• Eval / scorecard harness&#xa;&#xa;&lt;b&gt;PROCESS OWNERS (governance — policy, gates, audit)&lt;/b&gt;&#xa;• Gate taxonomy (which G, which H, where)&#xa;• OPA / Rego policy bundles&#xa;• HITL Console UX + approval SLAs&#xa;• Audit log retention + replay procedure&#xa;• MCP allow-list approvals + InfoSec sign-off&#xa;• Compliance evidence packs&#xa;• Incident response / on-call runbook for agent failures&#xa;&#xa;&lt;b&gt;Action:&lt;/b&gt; assign named owners (RACI) before Lighthouse kick-off." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="1930" y="2640" width="500" height="320" as="geometry"/>
                </mxCell>
                <mxCell id="rev-stages" value="&lt;b&gt;9. LIFECYCLE STAGES — overlay Plan → Build → Verify → Secure → Release → Observe → Improve&lt;/b&gt;&lt;br&gt;&lt;br&gt;Today the diagram is organised by &lt;b&gt;layer&lt;/b&gt; (triggers / control / execution).&#xa;Add a thin horizontal band along the top labelling lifecycle stages so reviewers see:&#xa;&#xa;• What we have today: &lt;b&gt;Plan + Build&lt;/b&gt; (and partial Verify)&#xa;• What&#39;s missing: &lt;b&gt;Secure, Release, Observe, Improve&lt;/b&gt;&#xa;• Where future agents land (Tester, SecOps, Release) without redesigning the layer view&#xa;&#xa;&lt;b&gt;Feedback arrow:&lt;/b&gt; Observe → Improve → Plan (dotted), so the loop is visibly closed.&#xa;Failures re-enter the &lt;b&gt;responsible agent&lt;/b&gt;, NOT the start of the pipeline." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="2620" y="2550" width="540" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="rev-oos" value="&lt;b&gt;10. EXPLICITLY OUT OF SCOPE (Phase 2+)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Pre-empt review questions by labelling these as deferred:&#xa;&#xa;• &lt;b&gt;Platform Agent / IaC MCP / Terraform&lt;/b&gt;&#xa;• &lt;b&gt;SRE Agent / PagerDuty / Dynatrace&lt;/b&gt;&#xa;• &lt;b&gt;Release Agent / ServiceNow / ArgoCD&lt;/b&gt;&#xa;• &lt;b&gt;Graph DB context store&lt;/b&gt; (using SQL+repo until #6 answered)&#xa;• &lt;b&gt;Temporal&lt;/b&gt; (LangGraph for Lighthouse)&#xa;• &lt;b&gt;Cross-cluster orchestrator&lt;/b&gt;&#xa;• &lt;b&gt;Parallel multi-ticket execution&lt;/b&gt; (sequential day 1)&#xa;&#xa;Show on diagram as faded/grey cluster with &quot;Phase 2+&quot; tag." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="3080" y="2110" width="380" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="rev-mark-lighthouse" value="LIGHTHOUSE PoC scope marker — Req → Architect → Coder → Tester only; everything else read-only" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="332" width="900" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="rev-mark-sor" value="see #2: Jira = SoR for stories; State Store = process-of-record only — avoid dual-write" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8dc;strokeColor=#999999;fontSize=10;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="1810" y="540" width="430" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="rev-mark-tier" value="see #5: replace any model name here with capability tier (T1/T2/T3/T4) + compliance tag" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="2255" y="1162" width="430" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="rev-mark-ctx" value="see #6: Context Engine — answer isolation / eviction / cross-story leakage before adding a graph/vector DB" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="732.5" y="1526" width="500" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="rev-mark-mcp" value="see #3: each MCP needs manifest (owner, internal/3rd-party, R/W split, allow-list, scoped creds)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="2260" y="1535" width="430" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="" style="shape=image;html=1;verticalAlign=top;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;imageAspect=0;aspect=fixed;image=https://icons.diagrams.net/icon-cache1/Boxicons_Regular_Vol_1-2633/bx-brain-800.svg" parent="1" vertex="1">
                    <mxGeometry x="1747" y="819" width="24" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="ueNlDixZYggd2Ir2u6uq-5" value="" style="shape=image;html=1;verticalAlign=top;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;imageAspect=0;aspect=fixed;image=https://icons.diagrams.net/icon-cache1/Boxicons_Regular_Vol_1-2633/bx-brain-800.svg" parent="1" vertex="1">
                    <mxGeometry x="2458" y="670" width="24" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="ueNlDixZYggd2Ir2u6uq-6" value="VERIFY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1729.5" y="1277" width="45" height="14" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="triggers-detail" name="Triggers Detail">
        <mxGraphModel dx="1257" dy="821" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="Trigger Channels — Detailed Flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1620" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;Solid arrow = trigger / inbound&#xa;Dashed arrow = notification / mirror (outbound)&#xa;Day 1 = Jira trigger only&#xa;Phase 2 = FleetOps + Cortex chat&#xa;Notifications = MS Teams (read-only)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8dc;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="40" y="80" width="280" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="g_j" value="Channel 1 — Jira (Day 1, system of record)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="220" width="1620" height="290" as="geometry"/>
                </mxCell>
                <mxCell id="j_human" value="Human&#xa;(developer)" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="290" width="40" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_jira" value="Jira&#xa;status: Ready for agent&#xa;⇄ Awaiting human review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="180" y="280" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_whr" value="Webhook Receiver&#xa;(verify signature,&#xa;dedupe by delivery id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="430" y="280" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_lookup" value="State Store lookup&#xa;active gate? gate_id?&#xa;last bot_comment_id?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="680" y="280" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_parse" value="Parse newest human comment&#xa;for /approve, /reject &lt;reason&gt;,&#xa;/clarify &lt;answer&gt;, /retry, /cancel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="930" y="280" width="240" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_orch" value="Orchestrator&#xa;(start / resume gate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1220" y="280" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_back" value="Bot comment + status flip&#xa;back to Awaiting human review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="280" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_note" value="&lt;b&gt;Loop semantics&lt;/b&gt;&lt;br&gt;Only TWO Jira statuses: &lt;i&gt;Ready for agent&lt;/i&gt; (trigger edge) and &lt;i&gt;Awaiting human review&lt;/i&gt; (parked at a gate). Fine-grained workflow state lives in the SQLite state store, never in Jira. The bot posts a single structured comment per gate with allowed slash-commands; the human replies and flips status to &lt;i&gt;Ready for agent&lt;/i&gt;. The receiver only scans comments newer than the bot marker, authored by humans. Idempotency = (ticket_id, gate_id, resolving_comment_id)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="420" width="1560" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_e1" value="status change" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_human" target="j_jira" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e2" value="webhook" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_jira" target="j_whr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e3" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_whr" target="j_lookup" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e4" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_lookup" target="j_parse" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e5" value="match" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_parse" target="j_orch" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e6" value="no match" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="j_parse" target="j_back" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e7" value="comment + PR link" style="endArrow=block;html=1;rounded=0;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;entryPerimeter=0;" parent="1" source="j_orch" target="j_jira" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1190" y="400"/>
                            <mxPoint x="910" y="400"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="g_3a" value="Channel 2 — Cortex FleetOps (Phase 2 — Day 1 candidate, fan-out across repos)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="520" width="1620" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="f_human" value="Platform&#xa;owner" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="600" width="40" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="f_cortex" value="Cortex FleetOps plugin&#xa;pick task + N services&#xa;(sequential day 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="180" y="590" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="f_mw" value="FleetOps Middleware&#xa;auth (Cortex SSO)&#xa;ticket fan-out&#xa;create epic + N tickets&#xa;idempotency keys" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="450" y="580" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="f_jira_create" value="Jira&#xa;Epic + child tickets&#xa;(status: Ready for agent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="720" y="580" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="f_whr" value="Webhook Receiver&#xa;(same as Channel 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="990" y="600" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="f_orch" value="Orchestrator runs&#xa;sequentially per ticket&#xa;(day 1) — parallel later" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="600" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="f_pr" value="PR per repo&#xa;+ digest comment back&#xa;to each child ticket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" parent="1" vertex="1">
                    <mxGeometry x="1490" y="600" width="160" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="f_e1" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_human" target="f_cortex" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e2" value="HTTPS + SSO" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_cortex" target="f_mw" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e3" value="acli / API" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_mw" target="f_jira_create" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e4" value="status webhook" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_jira_create" target="f_whr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e5" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_whr" target="f_orch" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e6" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="f_orch" target="f_pr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_note" value="&lt;b&gt;Why FleetOps as middleware (not direct Cortex → control plane)&lt;/b&gt;&lt;br&gt;Centralises auth, schema validation, rate limiting, and the fan-out logic that creates an epic + N child tickets. Once tickets exist, the rest of the flow reuses Channel 1 — the Webhook Receiver does not need to know whether the trigger originated from a human in Jira or from Cortex. This keeps a single state machine and a single resume path. Day 1: sequential execution per ticket (small blast radius). Phase 2: parallel with concurrency cap." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="740" width="1560" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="g_3b" value="Channel 3 — Cortex per-service chat plugin (Phase 2)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="870" width="1620" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="c_human" value="Service&#xa;owner" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="950" width="40" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="c_chat" value="Cortex service page&#xa;agent chat plugin&#xa;ticket id input + chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="180" y="940" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="c_mw" value="FleetOps Middleware&#xa;same component, route:&#xa;POST /v1/runs (start)&#xa;POST /v1/runs/{id}/gate&#xa;GET  /v1/runs/{id}/events (SSE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="450" y="930" width="240" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="c_whr" value="Webhook Receiver&#xa;(start_workflow + gate_resolve)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="740" y="950" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="c_orch" value="Orchestrator&#xa;streams events back" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="950" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="c_jira" value="Jira&#xa;digest comments&#xa;(audit + final PR link)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="950" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="c_e1" style="endArrow=block;html=1;rounded=0;" parent="1" source="c_human" target="c_chat" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e2" value="HTTPS + SSO" style="endArrow=block;html=1;rounded=0;" parent="1" source="c_chat" target="c_mw" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e3" style="endArrow=block;html=1;rounded=0;" parent="1" source="c_mw" target="c_whr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e4" style="endArrow=block;html=1;rounded=0;" parent="1" source="c_whr" target="c_orch" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e5" value="SSE events" style="endArrow=classic;startArrow=classic;html=1;rounded=0;dashed=1;" parent="1" source="c_orch" target="c_chat" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e6" value="digest mirror" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="c_orch" target="c_jira" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_note" value="&lt;b&gt;Per-service chat — interaction surface, not source of truth&lt;/b&gt;&lt;br&gt;The plugin gives a real conversational UI for clarifications and rich plan rendering (markdown, diffs, syntax highlighting) that Jira comments can&#39;t deliver. Jira remains authoritative: every gate decision and the final PR link are mirrored back as digest comments. If Cortex is down, the developer falls back to the Jira channel — no run is stranded. Auth is handled by the FleetOps Middleware via Cortex SSO." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1050" width="1560" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="g_n" value="Notifications (all channels) — outbound only, never accept gate decisions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=14;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1130" width="1620" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="n_orch" value="Orchestrator&#xa;(gate opened / failure /&#xa;long-waiting gate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="180" y="1180" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_teams" value="MS Teams&#xa;adaptive card with link to&#xa;Jira / Cortex (no buttons)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="500" y="1180" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_human" value="Human" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
                    <mxGeometry x="840" y="1180" width="40" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_back" value="acts in Jira or Cortex&#xa;(notification has no gate buttons)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;" parent="1" vertex="1">
                    <mxGeometry x="940" y="1180" width="260" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_e1" value="post card" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="n_orch" target="n_teams" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="n_e2" value="ping" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="n_teams" target="n_human" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="n_e3" value="click → opens Jira/Cortex" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="n_human" target="n_back" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="n_note" value="Teams is a pure notifier in v1: it does not carry gate state, does not accept slash-commands, and is not a fallback if Jira/Cortex are down. Promoting Teams to interactive (Adaptive Card buttons that POST decisions through the FleetOps Middleware) is a phase-2 option." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="1170" width="400" height="80" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
