                <mxCell id="EdAH23wTT8TAoaTBZzOQ-24" value="Job Dispatcher (AKS)&lt;br&gt;consumes execute-jobs&lt;br&gt;creates K8s Jobs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;dashed=1;fontStyle=2;" parent="1" vertex="1">
