            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="Trigger Channels — Detailed Flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1620" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;Solid arrow = trigger / inbound&#xa;Dashed arrow = notification / mirror (outbound)&#xa;Day 1 = Jira trigger only&#xa;Phase 2 = FleetOps + Cortex chat&#xa;Notifications = MS Teams (read-only)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8dc;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="40" y="80" width="280" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="g_j" value="Channel 1 — Jira (Day 1, system of record)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="220" width="1620" height="290" as="geometry"/>
                </mxCell>
                <mxCell id="j_human" value="Human&#xa;(developer)" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="290" width="40" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_jira" value="Jira&#xa;status: Ready for agent&#xa;⇄ Awaiting human review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="180" y="280" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_whr" value="Webhook Receiver&#xa;(verify signature,&#xa;dedupe by delivery id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="430" y="280" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_lookup" value="State Store lookup&#xa;active gate? gate_id?&#xa;last bot_comment_id?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="680" y="280" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_parse" value="Parse newest human comment&#xa;for /approve, /reject &lt;reason&gt;,&#xa;/clarify &lt;answer&gt;, /retry, /cancel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="930" y="280" width="240" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_orch" value="Orchestrator&#xa;(start / resume gate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1220" y="280" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_back" value="Bot comment + status flip&#xa;back to Awaiting human review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="1460" y="280" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_note" value="&lt;b&gt;Loop semantics&lt;/b&gt;&lt;br&gt;Only TWO Jira statuses: &lt;i&gt;Ready for agent&lt;/i&gt; (trigger edge) and &lt;i&gt;Awaiting human review&lt;/i&gt; (parked at a gate). Fine-grained workflow state lives in the SQLite state store, never in Jira. The bot posts a single structured comment per gate with allowed slash-commands; the human replies and flips status to &lt;i&gt;Ready for agent&lt;/i&gt;. The receiver only scans comments newer than the bot marker, authored by humans. Idempotency = (ticket_id, gate_id, resolving_comment_id)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="420" width="1560" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="j_e1" value="status change" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_human" target="j_jira" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e2" value="webhook" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_jira" target="j_whr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e3" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_whr" target="j_lookup" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e4" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_lookup" target="j_parse" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e5" value="match" style="endArrow=block;html=1;rounded=0;" parent="1" source="j_parse" target="j_orch" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e6" value="no match" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="j_parse" target="j_back" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="j_e7" value="comment + PR link" style="endArrow=block;html=1;rounded=0;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;entryPerimeter=0;" parent="1" source="j_orch" target="j_jira" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1190" y="400"/>
                            <mxPoint x="910" y="400"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="g_3a" value="Channel 2 — Cortex FleetOps (Phase 2 — Day 1 candidate, fan-out across repos)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="520" width="1620" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="f_human" value="Platform&#xa;owner" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="600" width="40" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="f_cortex" value="Cortex FleetOps plugin&#xa;pick task + N services&#xa;(sequential day 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="180" y="590" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="f_mw" value="FleetOps Middleware&#xa;auth (Cortex SSO)&#xa;ticket fan-out&#xa;create epic + N tickets&#xa;idempotency keys" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="450" y="580" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="f_jira_create" value="Jira&#xa;Epic + child tickets&#xa;(status: Ready for agent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="720" y="580" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="f_whr" value="Webhook Receiver&#xa;(same as Channel 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="990" y="600" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="f_orch" value="Orchestrator runs&#xa;sequentially per ticket&#xa;(day 1) — parallel later" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="600" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="f_pr" value="PR per repo&#xa;+ digest comment back&#xa;to each child ticket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" parent="1" vertex="1">
                    <mxGeometry x="1490" y="600" width="160" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="f_e1" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_human" target="f_cortex" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e2" value="HTTPS + SSO" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_cortex" target="f_mw" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e3" value="acli / API" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_mw" target="f_jira_create" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e4" value="status webhook" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_jira_create" target="f_whr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e5" style="endArrow=block;html=1;rounded=0;" parent="1" source="f_whr" target="f_orch" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_e6" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="f_orch" target="f_pr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="f_note" value="&lt;b&gt;Why FleetOps as middleware (not direct Cortex → control plane)&lt;/b&gt;&lt;br&gt;Centralises auth, schema validation, rate limiting, and the fan-out logic that creates an epic + N child tickets. Once tickets exist, the rest of the flow reuses Channel 1 — the Webhook Receiver does not need to know whether the trigger originated from a human in Jira or from Cortex. This keeps a single state machine and a single resume path. Day 1: sequential execution per ticket (small blast radius). Phase 2: parallel with concurrency cap." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="740" width="1560" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="g_3b" value="Channel 3 — Cortex per-service chat plugin (Phase 2)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="40" y="870" width="1620" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="c_human" value="Service&#xa;owner" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="950" width="40" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="c_chat" value="Cortex service page&#xa;agent chat plugin&#xa;ticket id input + chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="180" y="940" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="c_mw" value="FleetOps Middleware&#xa;same component, route:&#xa;POST /v1/runs (start)&#xa;POST /v1/runs/{id}/gate&#xa;GET  /v1/runs/{id}/events (SSE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="450" y="930" width="240" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="c_whr" value="Webhook Receiver&#xa;(start_workflow + gate_resolve)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="740" y="950" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="c_orch" value="Orchestrator&#xa;streams events back" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="950" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="c_jira" value="Jira&#xa;digest comments&#xa;(audit + final PR link)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="950" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="c_e1" style="endArrow=block;html=1;rounded=0;" parent="1" source="c_human" target="c_chat" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e2" value="HTTPS + SSO" style="endArrow=block;html=1;rounded=0;" parent="1" source="c_chat" target="c_mw" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e3" style="endArrow=block;html=1;rounded=0;" parent="1" source="c_mw" target="c_whr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e4" style="endArrow=block;html=1;rounded=0;" parent="1" source="c_whr" target="c_orch" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e5" value="SSE events" style="endArrow=classic;startArrow=classic;html=1;rounded=0;dashed=1;" parent="1" source="c_orch" target="c_chat" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_e6" value="digest mirror" style="endArrow=block;html=1;rounded=0;dashed=1;" parent="1" source="c_orch" target="c_jira" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="c_note" value="&lt;b&gt;Per-service chat — interaction surface, not source of truth&lt;/b&gt;&lt;br&gt;The plugin gives a real conversational UI for clarifications and rich plan rendering (markdown, diffs, syntax highlighting) that Jira comments can&#39;t deliver. Jira remains authoritative: every gate decision and the final PR link are mirrored back as digest comments. If Cortex is down, the developer falls back to the Jira channel — no run is stranded. Auth is handled by the FleetOps Middleware via Cortex SSO." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1050" width="1560" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="g_n" value="Notifications (all channels) — outbound only, never accept gate decisions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=14;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1130" width="1620" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="n_orch" value="Orchestrator&#xa;(gate opened / failure /&#xa;long-waiting gate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="180" y="1180" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_teams" value="MS Teams&#xa;adaptive card with link to&#xa;Jira / Cortex (no buttons)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="500" y="1180" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="n_human" value="Human" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
                    <mxGeometry x="840" y="1180" width="40" height="60" as="geometry"/>
                </mxCell>
