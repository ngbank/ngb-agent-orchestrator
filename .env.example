# Agent Orchestrator Environment Configuration
# DO NOT edit secrets directly — this file is a template populated by setup-env.sh.
# Secrets are stored in 1Password (vault: "NG Bank", item: "NGB Agent Orchestrator").
# NEVER commit the generated .env file to version control.

# ==========================================
# JIRA Configuration
# ==========================================
# Your Atlassian JIRA Cloud URL (stored in 1Password)
JIRA_URL=__JIRA_URL__

# Your JIRA email address (stored in 1Password)
JIRA_EMAIL=__JIRA_EMAIL__

# JIRA API Token (stored in 1Password)
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=__JIRA_API_TOKEN__

# ==========================================
# LLM Provider Credentials
# Set GOOSE_MODEL to a LiteLLM model string — the provider is inferred automatically.
# Format: "provider/model-name"
# No proxy server is required; routing happens via the LiteLLM Python SDK.
# ==========================================

# --- Azure AI Foundry / Azure OpenAI (model prefix: azure/) ---
# e.g. GOOSE_MODEL=azure/gpt-4.1  or  GOOSE_MODEL=azure/gpt-5.3-codex
# Azure OpenAI resource key (stored in 1Password)
AZURE_API_KEY=__AZURE_API_KEY__

# Full endpoint URL of your Azure OpenAI resource
AZURE_API_BASE=https://ai-agentic-guild.cognitiveservices.azure.com

# Azure OpenAI API version (fallback for models not listed in graph/utils.py _AZURE_API_VERSIONS)
# Known models (gpt-4.1, gpt-5.3-codex) have their API versions hardcoded — no need to set this.
# AZURE_API_VERSION=2024-12-01-preview

# --- Anthropic (model prefix: anthropic/) e.g. GOOSE_MODEL=anthropic/claude-3-5-sonnet-20241022 ---
# Generate at: https://console.anthropic.com/settings/keys (stored in 1Password)
ANTHROPIC_API_KEY=__ANTHROPIC_API_KEY__

# ==========================================
# Goose Configuration
# ==========================================
# LiteLLM model string — the provider is inferred from the prefix:
#   anthropic/claude-3-5-sonnet-20241022  → uses ANTHROPIC_API_KEY
#   azure/gpt-4.1                         → uses AZURE_API_KEY + AZURE_API_BASE (API version auto-selected)
#   azure/gpt-5.3-codex                   → uses AZURE_API_KEY + AZURE_API_BASE (API version auto-selected)
#   openai/gpt-4o  or  gpt-4o            → uses OPENAI_API_KEY
# Azure model API versions are resolved automatically in graph/utils.py — no override needed.
GOOSE_MODEL=azure/gpt-5.3-codex

# Python interpreter used to launch the MCP server
# Populated dynamically by setup-env.sh based on the project directory.
GOOSE_MCP_PYTHON=__GOOSE_MCP_PYTHON__

# ==========================================
# Database Configuration
# ==========================================
# Path to SQLite database for orchestration state
DATABASE_PATH=./state/orchestrator.db

# Path to SQLite database for workflow state tracking
DB_PATH=state/local.db

# ==========================================
# Orchestrator Settings
# ==========================================
# Default project key for work items
DEFAULT_PROJECT_KEY=AOS

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==========================================
# GitHub App Authentication
# ==========================================
# All GitHub operations (clone, push, PR) use a GitHub App installation token.
# The gh CLI is no longer required.
# Instructions: https://docs.github.com/en/apps/creating-github-apps/about-creating-github-apps/about-creating-github-apps
GITHUB_APP_ID=__GITHUB_APP_ID__
GITHUB_APP_PRIVATE_KEY=__GITHUB_APP_PRIVATE_KEY__
GITHUB_APP_INSTALLATION_ID=__GITHUB_APP_INSTALLATION_ID__

# ==========================================
# OpenTelemetry (Day-0 Tracing)
# ==========================================
# Comma-separated list of exporters: "console" (stdout), "otlp" (remote collector).
# File logging (LOGS_DIR/<workflow_id>/otel.jsonl) is always on regardless of this setting.
# Leave empty or unset for file-only export (no forwarding).
OTEL_EXPORTERS=console

# Service name attached to all spans (optional — defaults to "ngb-agent-orchestrator")
# OTEL_SERVICE_NAME=ngb-agent-orchestrator

# gRPC endpoint for the OTLP exporter (only used when OTEL_EXPORTERS includes "otlp")
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Debug mode: when true, disables redaction in local artifacts (preserves raw payloads for troubleshooting)
# Use only in local development — never enable in production
# OTEL_DEBUG_LOCAL=false

# Redaction mode: defaults to true (secure by default — independent of exporter type).
# Set to false only for local debugging. Never disable in production.
# OTEL_REDACT_PAYLOADS=true
