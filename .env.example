# Agent Orchestrator Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file to version control

# ==========================================
# JIRA Configuration
# ==========================================
# Your Atlassian JIRA Cloud URL
JIRA_URL=https://mirandags.atlassian.net

# Your JIRA email address
JIRA_EMAIL=your.email@example.com

# JIRA API Token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# ==========================================
# LiteLLM Proxy Configuration
# ==========================================
# Auth key for the LiteLLM proxy API (can be any string for local use)
LITELLM_MASTER_KEY=sk-local-master-key

# Model identifier passed to the provider (format: provider/model-name)
# Examples:
#   Anthropic:   anthropic/claude-3-5-sonnet-20241022
#   OpenAI:      gpt-4o
#   Azure:       azure/<AZURE_DEPLOYMENT_NAME>  (e.g. azure/gpt-4)
LITELLM_MODEL=anthropic/claude-3-5-sonnet-20241022

# URL of the running LiteLLM proxy (default port: 4000)
LITELLM_BASE_URL=http://localhost:4000

# ==========================================
# LLM Provider API Keys
# ==========================================
# --- Anthropic (e.g. LITELLM_MODEL=anthropic/claude-3-5-sonnet-20241022) ---
# Generate at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OpenAI (e.g. LITELLM_MODEL=gpt-4o) ---
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Azure AI Foundry / Azure OpenAI (e.g. LITELLM_MODEL=azure/gpt-4) ---
# Azure OpenAI resource key (found in Azure Portal → your resource → Keys and Endpoint)
AZURE_API_KEY=your_azure_api_key_here

# Full endpoint URL of your Azure OpenAI resource
# Found in Azure Portal → your resource → Keys and Endpoint
AZURE_API_BASE=https://<resource-name>.openai.azure.com/

# Azure OpenAI API version to use
# See supported versions: https://learn.microsoft.com/azure/ai-services/openai/reference
AZURE_API_VERSION=2024-02-01

# The deployment name you assigned to your model in Azure AI Foundry
# Used as the model suffix: azure/<AZURE_DEPLOYMENT_NAME>
AZURE_DEPLOYMENT_NAME=your_deployment_name_here

# ==========================================
# Goose Configuration
# ==========================================
# Point Goose at the LiteLLM proxy as its model provider
GOOSE_PROVIDER=openai

# Model name Goose uses — must match the model_name in config/litellm.yaml
GOOSE_MODEL=default

# Goose model base URL — point at the LiteLLM proxy
GOOSE_BASE_URL=http://localhost:4000

# ==========================================
# Database Configuration
# ==========================================
# Path to SQLite database for orchestration state
DATABASE_PATH=./state/orchestrator.db

# Path to SQLite database for workflow state tracking
DB_PATH=state/local.db

# ==========================================
# Orchestrator Settings
# ==========================================
# Default project key for work items
DEFAULT_PROJECT_KEY=AOS

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
