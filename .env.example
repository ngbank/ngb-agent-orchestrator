# Agent Orchestrator Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file to version control

# ==========================================
# JIRA Configuration
# ==========================================
# Your Atlassian JIRA Cloud URL
JIRA_URL=https://mirandags.atlassian.net

# Your JIRA email address
JIRA_EMAIL=your.email@example.com

# JIRA API Token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# ==========================================
# LiteLLM Proxy Configuration
# ==========================================
# Auth key for the LiteLLM proxy API (can be any string for local use)
LITELLM_MASTER_KEY=sk-local-master-key

# Model identifier passed to the provider (format: provider/model-name)
# Examples:
#   Anthropic: anthropic/claude-3-5-sonnet-20241022
#   OpenAI:    gpt-4o
LITELLM_MODEL=anthropic/claude-3-5-sonnet-20241022

# URL of the running LiteLLM proxy (default port: 4000)
LITELLM_BASE_URL=http://localhost:4000

# ==========================================
# LLM Provider API Keys
# ==========================================
# Anthropic API Key (required when using Anthropic backend)
# Generate at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (required when using OpenAI backend)
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# Goose Configuration
# ==========================================
# Point Goose at the LiteLLM proxy as its model provider
GOOSE_PROVIDER=openai

# Model name Goose uses — must match the model_name in config/litellm.yaml
GOOSE_MODEL=default

# Goose model base URL — point at the LiteLLM proxy
GOOSE_BASE_URL=http://localhost:4000

# ==========================================
# Database Configuration
# ==========================================
# Path to SQLite database for orchestration state
DATABASE_PATH=./state/orchestrator.db

# Path to SQLite database for workflow state tracking
DB_PATH=state/local.db

# ==========================================
# Orchestrator Settings
# ==========================================
# Default project key for work items
DEFAULT_PROJECT_KEY=AOS

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
