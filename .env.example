# Agent Orchestrator Environment Configuration
# DO NOT edit secrets directly — this file is a template populated by setup-env.sh.
# Secrets are stored in 1Password (vault: "NG Bank", item: "NGB Agent Orchestrator").
# NEVER commit the generated .env file to version control.

# ==========================================
# JIRA Configuration
# ==========================================
# Your Atlassian JIRA Cloud URL (stored in 1Password)
JIRA_URL=__JIRA_URL__

# Your JIRA email address (stored in 1Password)
JIRA_EMAIL=__JIRA_EMAIL__

# JIRA API Token (stored in 1Password)
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=__JIRA_API_TOKEN__

# ==========================================
# LiteLLM Proxy Configuration
# ==========================================
# Auth key for the LiteLLM proxy API
# NOTE: Enabling master_key requires a PostgreSQL database for key management.
# For local development this is left disabled in config/litellm.yaml.
# Set this and configure a database when deploying to a shared environment.
LITELLM_MASTER_KEY=sk-local-master-key

# URL of the running LiteLLM proxy (default port: 4000)
LITELLM_BASE_URL=http://localhost:4000

# ==========================================
# LLM Provider Credentials
# Only populate credentials for providers defined in config/litellm.yaml
# ==========================================

# --- Azure AI Foundry / Azure OpenAI (model_name: azure-gpt4) ---
# Azure OpenAI resource key (stored in 1Password)
AZURE_API_KEY=__AZURE_API_KEY__

# Full endpoint URL of your Azure OpenAI resource
AZURE_API_BASE=https://ai-agentic-guild.cognitiveservices.azure.com

# Azure OpenAI API version
# See: https://learn.microsoft.com/azure/ai-services/openai/reference
AZURE_API_VERSION=2024-12-01-preview

# Full model string passed to LiteLLM (format: azure/<deployment_name>)
AZURE_MODEL=azure/gpt-4.1

# --- Azure AI Foundry — gpt-5.3-codex (model_name: azure-codex) ---
# Uses Responses API with a different api-version from gpt-4.1
AZURE_CODEX_API_VERSION=2025-04-01-preview
AZURE_CODEX_MODEL=azure/gpt-5.3-codex

# --- Anthropic (model_name: claude) ---
# Generate at: https://console.anthropic.com/settings/keys (stored in 1Password)
ANTHROPIC_API_KEY=__ANTHROPIC_API_KEY__

# --- OpenAI (model_name: gpt4o) ---
# When routing through the LiteLLM proxy, set this to the LITELLM_MASTER_KEY value.
OPENAI_API_KEY=sk-local-master-key

# ==========================================
# Goose Configuration
# ==========================================
# Point Goose at the LiteLLM proxy as its model provider
GOOSE_PROVIDER=openai

# Default model Goose uses — must match a model_name in config/litellm.yaml
# Options: azure-gpt4 | azure-codex | claude | gpt4o
GOOSE_MODEL=azure-codex

# Goose model base URL — point at the LiteLLM proxy
OPENAI_BASE_URL=http://localhost:4000

# Python interpreter used to launch the MCP server
# Populated dynamically by setup-env.sh based on the project directory.
GOOSE_MCP_PYTHON=__GOOSE_MCP_PYTHON__

# ==========================================
# Database Configuration
# ==========================================
# Path to SQLite database for orchestration state
DATABASE_PATH=./state/orchestrator.db

# Path to SQLite database for workflow state tracking
DB_PATH=state/local.db

# ==========================================
# Orchestrator Settings
# ==========================================
# Default project key for work items
DEFAULT_PROJECT_KEY=AOS

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
