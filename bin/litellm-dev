#!/usr/bin/env python3
# litellm-dev — run a local LiteLLM proxy for interactive development /
# troubleshooting, using the *exact* config that dispatcher / orchestrator use
# at runtime.
#
# Why this exists:
#
#   The dispatcher's ``orchestrator.utils.goose_session`` spins up an
#   ephemeral per-workflow LiteLLM proxy from a YAML generated by
#   ``orchestrator.utils._litellm_config_yaml(GOOSE_MODEL)``. That generator
#   is the single source of truth for proxy configuration (drop_params,
#   request_timeout, otel callbacks, provider param mapping, etc.).
#
#   Historically ``config/litellm.yaml`` was maintained as a hand-written
#   reference config for developers who wanted to run a standalone proxy for
#   probing or curl testing. That file drifted from the generator and was
#   silently unused by every code path. This wrapper replaces it: it generates
#   the same YAML the dispatcher uses, so the dev proxy behaves identically
#   to the production one.
#
# Usage:
#
#   GOOSE_MODEL=azure/gpt-4.1 bin/litellm-dev              # port 4000
#   GOOSE_MODEL=azure/gpt-4.1 LITELLM_PORT=4100 bin/litellm-dev
#   bin/litellm-dev --help
#
# The proxy is single-model — matching how the dispatcher uses it.  Restart
# with a different ``GOOSE_MODEL`` to switch backends.

from __future__ import annotations

import argparse
import os
import shutil
import signal
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import NoReturn

REPO_ROOT = Path(__file__).resolve().parent.parent


def _die(msg: str, code: int = 1) -> NoReturn:
    print(f"[litellm-dev] ERROR: {msg}", file=sys.stderr)
    sys.exit(code)


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="litellm-dev",
        description=(
            "Run a local LiteLLM proxy using the same config generator the "
            "dispatcher uses at runtime. Reads GOOSE_MODEL from the "
            "environment; the proxy exposes an OpenAI-compatible endpoint on "
            "LITELLM_PORT (default 4000)."
        ),
    )
    parser.add_argument(
        "--port",
        type=int,
        default=int(os.environ.get("LITELLM_PORT", "4000")),
        help="Port to bind (default: $LITELLM_PORT or 4000)",
    )
    return parser.parse_args()


def main() -> None:
    args = _parse_args()

    model = os.environ.get("GOOSE_MODEL", "").strip()
    if not model:
        _die("GOOSE_MODEL is not set. Example: " "GOOSE_MODEL=azure/gpt-4.1 bin/litellm-dev")

    # Reuse the exact generator the dispatcher uses.  Import lazily so
    # ``--help`` works without a healthy venv.
    sys.path.insert(0, str(REPO_ROOT))
    try:
        from orchestrator.utils import _litellm_config_yaml
    except ImportError as exc:
        _die(
            f"Cannot import orchestrator.utils ({exc}). "
            "Activate the venv or run: .venv/bin/python -m pip install -e ."
        )

    litellm_bin = Path(sys.executable).parent / "litellm"
    if not litellm_bin.exists():
        litellm_bin_path = shutil.which("litellm")
        if litellm_bin_path is None:
            _die(
                "litellm CLI not found. Install with: "
                ".venv/bin/python -m pip install -r requirements.txt"
            )
        litellm_bin = Path(litellm_bin_path)

    config_yaml = _litellm_config_yaml(model)

    # LiteLLM's callback loader resolves ``otel.litellm_proxy_setup`` by
    # locating ``<config_dir>/otel/litellm_proxy_setup.py`` on disk before
    # falling back to a Python import.  Mirror what ``goose_session`` does:
    # put the config in a temp dir with a symlink to the repo's ``otel/``.
    session_dir = Path(tempfile.mkdtemp(prefix="litellm-dev-"))
    try:
        (session_dir / "otel").symlink_to(REPO_ROOT / "otel")
        config_path = session_dir / "litellm.yaml"
        config_path.write_text(config_yaml)

        env = os.environ.copy()
        env["PYTHONPATH"] = os.pathsep.join([str(REPO_ROOT), env.get("PYTHONPATH", "")]).rstrip(
            os.pathsep
        )

        print(
            f"[litellm-dev] model={model} port={args.port} " f"config={config_path}",
            file=sys.stderr,
        )

        # Exec-style: forward signals so Ctrl-C shuts the proxy cleanly.
        proc = subprocess.Popen(
            [str(litellm_bin), "--config", str(config_path), "--port", str(args.port)],
            env=env,
        )

        def _forward(signum: int, _frame: object) -> None:
            proc.send_signal(signum)

        signal.signal(signal.SIGINT, _forward)
        signal.signal(signal.SIGTERM, _forward)

        sys.exit(proc.wait())
    finally:
        shutil.rmtree(session_dir, ignore_errors=True)


if __name__ == "__main__":
    main()
