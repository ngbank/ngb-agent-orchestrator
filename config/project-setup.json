{
  "AOS": {
    "platform": "python",
    "setup_commands": [
      "(python3 -m venv venv || python -m venv venv) && test -f venv/bin/activate",
      ". venv/bin/activate && pip install -r requirements.txt -q",
      ". venv/bin/activate && pip install -r requirements-dev.txt -q",
      ". venv/bin/activate && pip install -e . -q",
      ". venv/bin/activate && pre-commit install"
    ],
    "test_command": ". venv/bin/activate && python3 -m pytest tests/ -q --tb=short",
    "lint_command": ". venv/bin/activate && pre-commit run --all-files",
    "vcs": {
      "commit_template": "feat({ticket_key}): {summary}\n\nImplements WorkPlan tasks for {ticket_key}.",
      "files_changed_command": "git diff --name-only HEAD && git ls-files --others --exclude-standard"
    }
  }
}
